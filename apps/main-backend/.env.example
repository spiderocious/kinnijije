NODE_ENV=development
PORT=9093
LOG_LEVEL=info

APP_BASE_URL=http://localhost:9093
WEB_BASE_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/kinnijije

# Auth — JWT (tokens returned in the response body; frontend stores in sessionStorage)
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=replace_me_with_a_long_random_string_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# AI provider: "openai" (default, needs OPENAI_API_KEY) or "mock" (deterministic, no key)
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o
OPENAI_PARSE_MODEL=gpt-4o-mini
OPENAI_GENERATE_MODEL=gpt-4o
OPENAI_WHISPER_MODEL=whisper-1

# Storage — external R2 file-service (frontend uploads direct; backend stores keys)
FILE_SERVICE_URL=https://go-file-service-production.up.railway.app

# Default recipe hero (until an admin uploads a real image per meal)
RECIPE_PLACEHOLDER_IMAGE=/recipe-placeholder.png
